.sn-welcome{font-size:var(--now-global-font-size--md, 14px);padding:var(--now-global-space--xl,20px) var(--now-global-space--xl,20px) var(--now-global-space--md,10px)}
}
.sn-welcome_borderless{border:none}
.sn-welcome-badge{align-items:center;background-color:RGB(var(--now-color--primary-1,30,133,109));border-radius:100%;color:RGB(var(--now-color--neutral-0,255,255,255));display:flex;font-size:40px;height:72px;justify-content:center;left:50%;margin-inline-start:-36px;position:absolute;text-align:center;top:-36px;width:72px}
@media (max-width:800px){
.sn-welcome-badge{font-size:24px;height:52px;margin-inline-start:-26px;top:-26px;width:52px}
}
.sn-welcome-badge.icon-collaboration::before{height:34px}
@media (max-width:800px){
.sn-welcome-badge.icon-collaboration::before{height:18px}
}
.sn-welcome-title{font-size:var(--now-global-font-size--xxl, 32px);margin:var(--now-global-space--md,10px) 0;text-align:center}
@media (max-width:800px){
.sn-welcome-title{font-size:var(--now-global-font-size--lg, 18px)}
}
.sn-welcome-content{color:RGB(var(--now-color_text--secondary,var(--now-color--neutral-15,44,53,55)));width:100%}
@media (max-width:800px){
.sn-welcome-content{padding-block-end:var(--now-global-space--xl,20px)}
}
.sn-welcome-content ul{list-style:disc outside;margin-block-end:var(--now-global-space--md,10px);padding-inline-start:var(--now-global-space--3xl,32px)}
.sn-welcome-content a{display:block;margin-block-end:var(--now-global-space--xs,4px)}
.sn-welcome-content a:focus,.sn-welcome-content a:hover{text-decoration:underline}
.sn-welcome-content a:focus::before,.sn-welcome-content a:hover::before{text-decoration:none}
.sn-welcome-content a::before{margin-block-start:calc(-1 * var(--now-global-space--xxs,2px));margin-inline-end:var(--now-global-space--sm,6px)}
.disable-ng-animations.ng-animate,.disable-ng-animations.ng-enter,.disable-ng-animations.ng-leave{transition:none!important}
.disable-ng-animations.ng-animate{animation:none 0s!important}
.navpage-right{background-color:RGB(var(--now-color_background--tertiary,var(--now-color--neutral-2,228,230,231)))}
.sn-highlight_positive{color:RGB(var(--now-alert_button-iconic--positive--color,var(--now-color_alert--positive-3,30,105,34)))}
.sn-highlight_negative{color:RGB(var(--now-alert_button-iconic--critical--color,var(--now-color_alert--critical-3,160,48,43)))}
.sn-light-box{background-color:RGBA(var(--now-color--neutral-21,0,0,0),.65)}
.sn-light-box .modal-dialog{display:flex;justify-content:center;margin:var(--now-global-space--xl,20px) auto 0;max-width:80vw;width:auto}
.sn-light-box .modal-content{background-color:transparent;border:none;box-shadow:none;min-width:20vw}
.sn-light-box .modal-header{border:none;padding:var(--now-global-space--sm,6px) 0}
.sn-light-box .modal-header .modal-title{width:80%}
.sn-light-box .modal-header .close{opacity:1;text-shadow:none}
.sn-light-box .modal-body{background-color:transparent;padding:0}
.sn-light-box .modal-body .sn-attachment-preview-image img{max-height:80vh}
.sn-light-box .modal-footer{border:none;padding:var(--now-global-space--sm,6px) 0}
.sn-light-box .modal-footer .btn.btn-icon,.sn-light-box .modal-footer .modal-title,.sn-light-box .modal-header .btn.btn-icon,.sn-light-box .modal-header .modal-title{color:RGB(var(--now-color--neutral-0,255,255,255))}
.sn-embedded-help{display:flex;flex-direction:column}
.sn-embedded-help .help-action .sn-widget .sn-widget{padding:0}
.sn-embedded-help .help-action .sn-widget .sn-widget .btn{margin-block-end:var(--now-global-space--md,10px)}
.sn-embedded-help-pane,.sn-embedded-help-pane-content{bottom:0;display:flex;flex-direction:column;left:0;position:absolute;right:0;top:0}
.sn-embedded-help-pane-content .sn-aside-header.open .sn-aside-btn:active,.sn-embedded-help-pane-content .sn-aside-header.open .sn-aside-btn:focus{opacity:1}
.sn-embedded-help-pane-content .sn-aside-header.open .sn-aside-btn .sn-widget-list_v2{display:block;position:absolute;top:50%;right:0}
.sn-embedded-help-pane-content .sn-aside-header.open .sn-aside-btn .sn-widget-list_v2 .sn-widget-list-item{background-color:RGB(var(--now-color_background--primary,var(--now-color--neutral-0,255,255,255)));color:RGB(var(--now-color_text--primary,var(--now-color--neutral-18,22,27,28)));min-height:40px}
.sn-embedded-help-pane-content .sn-aside-header.open .sn-aside-btn .sn-widget-list_v2 .sn-widget-list-item .sn-widget-list-title{color:RGB(var(--now-color_text--primary,var(--now-color--neutral-18,22,27,28)));font-size:var(--now-global-font-size--md, 14px)}
.skip-links:active,.skip-links:focus{background:RGB(var(--now-button--primary--background-color,var(--now-color--primary-1,30,133,109)));border-radius:4px;color:RGB(var(--now-button--primary--color,var(--now-color--neutral-0,255,255,255)));display:inline-block;left:var(--now-global-space--xs,4px);padding:var(--now-global-space--sm,6px) var(--now-global-space--md,10px);position:absolute;text-decoration:none;top:var(--now-global-space--xs,4px)}
