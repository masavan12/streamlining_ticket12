/*! RESOURCE: styles/snippets.css */
.sn-snippet-form .required-marker {
display: block !important; }

.sn-snippet-form .row {
border-bottom: none; }
.sn-snippet-form .row .btn {
margin-left: 10px; }

.sn-snippet-inline {
border: 1px solid #e7e9eb;
padding: 0; }
.sn-snippet-inline .sn-result-header {
border-bottom: 1px solid #e7e9eb;
padding: 6px 4px 6px 0; }
.sn-snippet-inline .sn-snippet-form {
margin-top: 10px; }
.sn-snippet-inline .sn-snippet-form .row {
margin: 0 0 10px; }

.sn-snippet-popover {
min-width: 340px;
margin: -9px -14px;
max-width: 340px; }
.sn-snippet-popover .sn-result-header {
display: none; }
.sn-snippet-popover .snippet-row .snippet-keyword {
display: none; }

.sn-snippet-search {
padding: 0; }
.sn-snippet-search.popover-body {
padding: 0; }
.sn-snippet-search.popover-body .row {
margin: 0; }

.sn-snippet-header {
border-bottom: 1px solid #e7e9eb; }
.sn-snippet-header.row {
margin: 0;
padding: 9px 14px; }
.sn-snippet-header h4 {
height: 31px;
display: inline-block;
line-height: 31px;
margin: 0;
width: 50%; }

.sn-snippet-body.row {
margin: 0;
padding: 0; }

.sn-snippet-body .no-snippets {
cursor: default;
font-size: 16px;
font-weight: bold;
padding: 20px 15px;
text-align: center; }

.sn-snippet-typeahead .twitter-typeahead {
width: 100%; }
.sn-snippet-typeahead .twitter-typeahead input {
background-color: RGB(var(--now-color--neutral-0,255,255,255)) !important;
border: 1px solid RGB(var(--now-color--neutral-2,240,241,245));
border-radius: 0;
border-width: 0 0 1px;
box-shadow: none;
font-size: 16px;
height: auto;
max-height: 200px;
overflow-x: hidden;
overflow-y: auto;
margin: 0;
padding: 10px 10px;
resize: none;
width: 100%; }
.sn-snippet-typeahead .twitter-typeahead input:focus {
outline: none; }
.sn-snippet-typeahead .twitter-typeahead pre {
height: 1px;
left: 0;
margin: 0;
padding: 0;
position: absolute;
top: 0;
width: 1px; }
.sn-snippet-typeahead .twitter-typeahead .no-results {
cursor: default;
font-weight: bold;
padding: 20px 15px;
text-align: center; }
.sn-snippet-typeahead .twitter-typeahead .header {
background-color: #e7e9eb;
border: 1px solid #e7e9eb;
border-width: 1px 0;
display: none;
font-size: 10px;
padding: 10px; }
.sn-snippet-typeahead .twitter-typeahead .tt-menu {
bottom: auto !important;
display: block !important;
left: auto !important;
height: 200px;
overflow-y: auto;
position: relative !important;
right: auto !important;
top: auto !important;
width: 100%; }
.sn-snippet-typeahead .twitter-typeahead .tt-menu .row {
margin: 0; }
.sn-snippet-typeahead .twitter-typeahead .tt-menu .snippet-row {
padding: 5px 0;
border-bottom: 1px solid #e7e9eb; }
.sn-snippet-typeahead .twitter-typeahead .tt-menu .snippet-row:hover .snippet-edit {
display: block; }
.sn-snippet-typeahead .twitter-typeahead .tt-menu .snippet-row.tt-cursor {
background-color: #e7e9eb; }
.sn-snippet-typeahead .twitter-typeahead .tt-menu .snippet-text {
padding-left: 0; }
.sn-snippet-typeahead .twitter-typeahead .tt-menu .snippet-edit {
cursor: pointer;
display: none;
padding-right: 0;
text-align: right; }

