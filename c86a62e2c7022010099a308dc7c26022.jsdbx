uxGlobals.theme.resolveProperties = (properties) => {
    const resolved = {};
    Object.entries(properties).forEach(([k, v]) => {
        resolved[k] = uxGlobals.theme.resolve(properties, v, new Set());
    })
    return resolved;
};
uxGlobals.theme.resolve = (properties, value, visited) => {
    if (visited.has(value))
        return value;
    if (value in properties) {
        visited.add(value);
        return uxGlobals.theme.resolve(properties, properties[value], visited);
    }
    return value;
};
